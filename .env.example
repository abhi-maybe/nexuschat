# NexusChat Configuration
# Copy this file to .env and fill in your values

# Server
HOST=0.0.0.0
PORT=8080
SECRET_KEY=your-secret-key-here

# Database
DATABASE_URL=sqlite:///./nexuschat.db

# AI Providers (optional - configure in Settings UI)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
XIAOMI_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Default model provider: ollama, openai, anthropic, deepseek, xiaomi, groq
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=llama3.2
